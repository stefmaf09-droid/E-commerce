# ==============================================================================
# Refundly.ai — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer le fichier .env (dans .gitignore)
# ==============================================================================

# ── Application ────────────────────────────────────────────────────────────────
DASHBOARD_URL=https://app.refundly.ai
ADMIN_EMAIL=admin@refundly.ai
ENV_MODE=PROD
SECRET_KEY=your-random-secret-key-here

# ── IA — Google Gemini ─────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Email SMTP ─────────────────────────────────────────────────────────────────
GMAIL_SENDER=no-reply@refundly.ai
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@refundly.ai
SMTP_PASSWORD=your-app-password-here
FROM_NAME=Refundly.ai

# ── Base de données ────────────────────────────────────────────────────────────
DB_PATH=data/recours_ecommerce.db
DATABASE_URL=postgresql://user:password@localhost:5432/refundly

# ── Transporteurs — APIs de suivi ──────────────────────────────────────────────
COLISSIMO_API_KEY=
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_USE_SANDBOX=false
DHL_API_KEY=
DHL_MERCHANT_ID=
GLS_API_KEY=
MONDIAL_RELAY_ENSEIGNE=
MONDIAL_RELAY_PASSWORD=
DPD_DELIS_ID=
DPD_PASSWORD=

# ── Webhooks ───────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=your-webhook-secret-here

# ── Paiements Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_MODE=test
PLATFORM_COMMISSION_RATE=0.20

# ── Intégrations E-commerce ────────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
BIGCOMMERCE_CLIENT_ID=
BIGCOMMERCE_CLIENT_SECRET=

# ── Workers / Performance ─────────────────────────────────────────────────────
SCRAPING_RATE_LIMIT=0.5
SYNC_INTERVAL_HOURS=24

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
